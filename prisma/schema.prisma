generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  member
  viewer
}

enum AssetKind {
  image
  video
  audio
  text
  document
  other
}

enum AssetStatus {
  inbox
  triaging
  organized
  archived
}

enum TrustLevel {
  unverified
  low
  medium
  high
  official
}

enum SourceType {
  web
  manual
  discord
  import
}

enum StorageProvider {
  gdrive
  discord_url
  external_url
  local_none
}

enum EntityType {
  person
  place
  source
  event
  tag
}

enum TextType {
  title
  body
  description
  message_body
  ocr
  transcript
  note
  extracted
}

enum SourceKind {
  url
  discord_message
  drive_file
  manual
  other
}

enum AnnotationKind {
  note
  time_range
  text_span
  region
}

enum RelationType {
  parent_child
  derived_from
  reference
  same_content
}

enum ClearanceLevel {
  public
  internal
  confidential
  restricted
}

enum DossierAccessMode {
  private
  clearance
}

enum DossierItemKind {
  asset_ref
  external_link
  external_image
}

enum PlaceStatus {
  confirmed
  candidate
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  role         Role           @default(member)
  clearance    ClearanceLevel @default(internal)
  avatarUrl    String?
  discordId    String?        @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  createdAssets      Asset[]      @relation("AssetCreatedBy")
  updatedAssets      Asset[]      @relation("AssetUpdatedBy")
  assetTexts         AssetText[]  @relation("AssetTextCreatedBy")
  annotations        Annotation[] @relation("AnnotationCreatedBy")
  dossiers           Dossier[]
  auditLogs          AuditLog[]
  apiKeys            ApiKey[]
  invitation         Invitation?
  createdInvitations Invitation[] @relation("InvitationCreatedBy")
}

model Asset {
  id               String          @id @default(cuid())
  kind             AssetKind
  title            String          @default("")
  description      String          @default("")
  status           AssetStatus     @default(inbox)
  trustLevel       TrustLevel      @default(unverified)
  canonicalDate    DateTime?
  originalFilename String?
  mimeType         String?
  fileSize         Int?
  sha256           String?
  sourceType       SourceType      @default(manual)
  storageProvider  StorageProvider  @default(local_none)
  storageKey       String?
  storageUrl       String?
  thumbnailUrl     String?
  messageBodyPreview String?
  classification     ClearanceLevel @default(internal)

  // Discord metadata
  discordGuildId    String?
  discordChannelId  String?
  discordMessageId  String?
  discordMessageUrl String?
  discordAuthorId   String?
  discordAuthorName String?
  discordPostedAt   DateTime?

  createdById String?
  createdBy   User?   @relation("AssetCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?   @relation("AssetUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  texts           AssetText[]
  entities        AssetEntity[]
  sourceRecords   SourceRecord[]
  annotations     Annotation[]
  dossierItems    DossierItem[]
  testimonials    Testimonial[]
  relationsAsSource AssetRelation[] @relation("RelationSource")
  relationsAsTarget AssetRelation[] @relation("RelationTarget")

  @@index([sha256])
  @@index([status])
  @@index([kind])
  @@index([sourceType])
  @@index([trustLevel])
  @@index([canonicalDate])
  @@index([createdAt])
  @@index([classification])
}

model AssetText {
  id                String   @id @default(cuid())
  assetId           String
  asset             Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  textType          TextType
  content           String
  normalizedContent String   @default("")
  language          String?

  createdById String?
  createdBy   User?   @relation("AssetTextCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
}

model Entity {
  id             String     @id @default(cuid())
  type           EntityType
  canonicalName  String
  normalizedName String     @default("")
  aliases        Json       @default("[]")
  description    String     @default("")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  assets       AssetEntity[]
  testimonials Testimonial[]
  place        Place?

  @@unique([type, canonicalName])
}

model AssetEntity {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  entityId  String
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  roleLabel String?
  createdAt DateTime @default(now())

  @@unique([assetId, entityId])
  @@index([assetId])
  @@index([entityId])
}

model SourceRecord {
  id          String     @id @default(cuid())
  assetId     String
  asset       Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  sourceKind  SourceKind
  title       String     @default("")
  url         String?
  publisher   String?
  publishedAt DateTime?
  metadata    Json       @default("{}")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([assetId])
}

model Annotation {
  id        String         @id @default(cuid())
  assetId   String
  asset     Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  kind      AnnotationKind
  body      String
  startMs   Int?
  endMs     Int?
  textStart Int?
  textEnd   Int?
  bbox      Json?

  createdById String
  createdBy   User   @relation("AnnotationCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
}

model Dossier {
  id              String                  @id @default(cuid())
  ownerId         String
  owner           User                    @relation(fields: [ownerId], references: [id])
  title           String
  summary         String                  @default("")
  classification  ClearanceLevel          @default(internal)
  viewMode        DossierAccessMode       @default(private)
  editMode        DossierAccessMode       @default(private)

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  items           DossierItem[]
  placeCandidates DossierPlaceCandidate[]

  @@index([ownerId])
  @@index([classification])
  @@index([updatedAt])
}

model DossierItem {
  id                    String          @id @default(cuid())
  dossierId             String
  dossier               Dossier         @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  kind                  DossierItemKind @default(asset_ref)

  // kind=asset_ref
  assetId               String?
  asset                 Asset?          @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // kind=external_link
  externalUrl           String?

  // kind=external_image (stored in R2)
  externalImageKey      String?
  externalImageThumbKey String?

  // Common metadata
  caption               String          @default("")
  note                  String          @default("")

  // Excerpt (range selection from AssetText)
  excerpt               String          @default("")
  excerptType           TextType?
  excerptStart          Int?
  excerptEnd            Int?

  sortOrder             Int             @default(0)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([dossierId, assetId], map: "dossier_item_dossier_asset_unique")
  @@index([dossierId])
  @@index([assetId])
}

model DossierPlaceCandidate {
  id            String   @id @default(cuid())
  dossierId     String
  dossier       Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  placeId       String?
  place         Place?   @relation(fields: [placeId], references: [id], onDelete: SetNull)

  // Inline fallback fields when placeId is null
  name          String   @default("")
  latitude      Float?
  longitude     Float?
  address       String?
  googleMapsUrl String?
  note          String   @default("")
  confidence    Int      @default(0)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([dossierId])
  @@index([placeId])
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String    // 先頭8文字を保持（UI表示用）
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  permissions Json      @default("[\"read\",\"write\"]") // 許可する操作
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([keyHash])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  targetType String
  targetId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model AssetRelation {
  id           String       @id @default(cuid())
  sourceId     String
  source       Asset        @relation("RelationSource", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId     String
  target       Asset        @relation("RelationTarget", fields: [targetId], references: [id], onDelete: Cascade)
  relationType RelationType
  metadata     Json         @default("{}")
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())

  @@unique([sourceId, targetId, relationType])
  @@index([sourceId, relationType])
  @@index([targetId, relationType])
}

model Invitation {
  id          String         @id @default(cuid())
  token       String         @unique @default(cuid())
  email       String?
  role        Role           @default(member)
  clearance   ClearanceLevel @default(internal)
  expiresAt   DateTime
  usedAt      DateTime?
  usedById    String?        @unique
  usedBy      User?          @relation(fields: [usedById], references: [id])
  createdById String
  createdBy   User           @relation("InvitationCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())

  @@index([token])
  @@index([createdById])
}

enum TestimonialStatus {
  pending
  approved
  rejected
}

enum TestimonialCategory {
  personality
  performance
  relationship
}

model Testimonial {
  id              String              @id @default(cuid())
  assetId         String
  asset           Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  entityId        String
  entity          Entity              @relation(fields: [entityId], references: [id], onDelete: Cascade)

  quote           String
  trait           String              @default("")
  category        TestimonialCategory @default(personality)
  speakerName     String
  speakerEntityId String?
  sourceUrl       String?
  sourceDate      DateTime?

  status          TestimonialStatus   @default(pending)
  confidence      Float               @default(0)

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  reviewedAt      DateTime?

  @@unique([assetId, entityId, quote])
  @@index([entityId, status])
  @@index([category])
  @@index([status])
}

model Place {
  id             String         @id @default(cuid())
  entityId       String         @unique
  entity         Entity         @relation(fields: [entityId], references: [id], onDelete: Cascade)
  latitude       Float
  longitude      Float
  googleMapsUrl  String?
  address        String?
  classification ClearanceLevel @default(internal)
  status         PlaceStatus    @default(confirmed)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  dossierCandidates DossierPlaceCandidate[]

  @@index([latitude, longitude])
  @@index([classification])
  @@index([status])
}

// ============================================================
// レポ収集 (curepo 由来) — Twitter ミーグリレポ収集・選別
// ============================================================

enum RepoTweetStatus {
  undecided
  keep
  reject
}

model RepoCollection {
  id              String         @id @default(cuid())
  name            String
  groups          Json           // [{ tags: string[], op: "and" | "or" }]
  groupOp         String         @default("or")
  query           String         // 構築済み X API クエリ（日付は別送信）
  startDate       String? // JST "YYYY-MM-DD"（TZ事故回避のため文字列保持）
  endDate         String?
  excludeRetweets Boolean        @default(true)
  langJa          Boolean        @default(true)
  extra           String         @default("")
  classification  ClearanceLevel @default(internal)
  sourceLegacyId  Int?           @unique // 移行の冪等化（curepo の整数 id）
  lastFetchedAt   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tweets RepoTweet[]

  @@index([classification])
}

model RepoTweet {
  id             String          @id @default(cuid())
  collectionId   String
  collection     RepoCollection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  tweetId        String
  authorUsername String          @default("")
  authorName     String          @default("")
  text           String          @default("")
  tweetedAt      DateTime?
  likeCount      Int             @default(0)
  retweetCount   Int             @default(0)
  replyCount     Int             @default(0)
  quoteCount     Int             @default(0)
  url            String
  status         RepoTweetStatus @default(undecided)
  note           String          @default("")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  media RepoTweetMedia[]

  @@unique([collectionId, tweetId])
  @@index([collectionId, status])
}

model RepoTweetMedia {
  id        String    @id @default(cuid())
  tweetId   String
  tweet     RepoTweet @relation(fields: [tweetId], references: [id], onDelete: Cascade)
  mediaKey  String
  type      String    @default("photo") // photo | video | animated_gif
  remoteUrl String? // 元 Twitter 画像URL（参照/再取得用）
  imageKey  String? // R2 key（640px WebP）
  width     Int?
  height    Int?
  altText   String    @default("")

  @@unique([tweetId, mediaKey])
}
