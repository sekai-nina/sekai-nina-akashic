# PostgreSQL (docker-compose.yml でも使われます)
POSTGRES_USER="akashic"
POSTGRES_PASSWORD="akashic"
POSTGRES_DB="akashic"
DATABASE_URL="postgresql://akashic:akashic@localhost:5432/akashic?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Discord Bot
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""

# Google Drive (optional — OAuth2 方式: 個人ドライブ向け)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REFRESH_TOKEN=""      # pnpm tsx scripts/get-drive-token.ts で取得
# GOOGLE_DRIVE_FOLDER_ID=""

# Google Drive (optional — サービスアカウント方式: 共有ドライブ向け)
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
