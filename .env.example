# Supabase PostgreSQL
# DATABASE_URL: Transaction pooler (port 6543) — アプリ接続用
# DIRECT_URL:   Direct connection (port 5432) — マイグレーション用
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ローカル開発用 (docker-compose.yml)
# DATABASE_URL="postgresql://akashic:akashic@localhost:5432/akashic?schema=public"
# DIRECT_URL="postgresql://akashic:akashic@localhost:5432/akashic?schema=public"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."   # サーバー側のみ。ユーザー管理に使用

# Discord Bot
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""

# Google Drive (optional — OAuth2 方式: 個人ドライブ向け)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REFRESH_TOKEN=""      # pnpm tsx scripts/get-drive-token.ts で取得
# GOOGLE_DRIVE_FOLDER_ID=""

# Google Drive (optional — サービスアカウント方式: 共有ドライブ向け)
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
